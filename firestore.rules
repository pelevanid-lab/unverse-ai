rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && (
        request.auth.uid == userId || 
        (resource != null && resource.data.authUid == request.auth.uid) ||
        (get(/databases/$(database)/documents/users/$(userId)).data.authUid == request.auth.uid)
      );
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if true; // Public for discovery and profile view
      
      // Users can update their basic profile, Admins can update everything
      allow update: if (isOwner(userId) 
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['ulcBalance', 'totalEarnings', 'totalSpent', 'isCreator', 'isFrozen', 'isAdmin']))
                    || isAdmin();
      
      // Prevent users from setting admin or financial flags during creation
      allow create: if isSignedIn() && userId == request.auth.uid
                    && !request.resource.data.hasAny(['isAdmin', 'isCreator', 'isFrozen', 'ulcBalance', 'totalEarnings']);
    }

    // Ledger (ReadOnly for users, Write only by backend)
    match /ledger/{entryId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.fromUserId) || 
        isOwner(resource.data.toUserId)
      );
      allow write: if false; 
    }

    // Subscriptions
    match /subscriptions/{subId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.userId) || 
        isOwner(resource.data.creatorId)
      );
      allow write: if false; 
    }

    // Claim Requests
    match /claim_requests/{claimId} {
      allow read: if isSignedIn() && isOwner(resource.data.creatorId);
      allow create: if isSignedIn() && isOwner(request.resource.data.creatorId);
      allow update: if false; 
    }

    // Vesting Schedules
    match /vesting_schedules/{scheduleId} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow write: if false; 
    }
    
    // Posts & Content
    match /posts/{postId} {
      allow read: if true; 
      allow write: if isSignedIn() && (
        resource == null || isOwner(resource.data.creatorId)
      );
    }

    // System Config (Public for floor price/settings)
    match /config/{configId} {
      allow read: if true; 
      allow write: if false; 
    }
    
    // Creator Media (Drafts/Processing)
    match /creator_media/{mediaId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.creatorId);
      allow create: if isSignedIn() && isOwner(request.resource.data.creatorId);
    }

    // AI Generation Logs
    match /ai_generation_logs/{logId} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isOwner(resource.data.userId);
    }
    
    // Chats & Messaging
    match /chats/{chatId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.subscriberId) || 
        isOwner(resource.data.creatorId)
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isOwner(resource.data.subscriberId) || 
        isOwner(resource.data.creatorId)
      );

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          isOwner(get(/databases/$(database)/documents/chats/$(chatId)).data.subscriberId) ||
          isOwner(get(/databases/$(database)/documents/chats/$(chatId)).data.creatorId)
        );
        allow create: if isSignedIn();
      }
    }

    // Presentations (Public Read)
    match /presentations/{docId} {
      allow read: if true;
      allow write: if false; 
    }

    // Forum topics and replies
    match /forum_topics/{topicId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isOwner(resource.data.authorId);
    }

    match /forum_replies/{replyId} {
      allow read: if true;
      allow create: if isSignedIn();
    }
    
    // Default fallback
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
