rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ BEYOND SECURITY: UNIFIED IDENTITY (CUSTOM CLAIMS & FALLBACK)
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && (
        request.auth.token.walletAddress == userId || 
        request.auth.uid == userId ||
        (exists(/databases/$(database)/documents/users/$(userId)) && 
         get(/databases/$(database)/documents/users/$(userId)).data.authUid == request.auth.uid)
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.isAdmin == true ||
        (request.auth.token.walletAddress != null && 
         exists(/databases/$(database)/documents/users/$(request.auth.token.walletAddress)) && 
         get(/databases/$(database)/documents/users/$(request.auth.token.walletAddress)).data.isAdmin == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    // 👤 USER PROFILES
    match /users/{userId} {
      allow read: if true;
      // 🔒 BALANCE PROTECTION: Users can update profile but NOT financial fields
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isAdmin() || 
                    (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ulcBalance', 'totalEarnings', 'totalSpent']));
      allow delete: if isAdmin();
    }

    // 📸 CREATOR MEDIA (Workshop / Drafts)
    match /creator_media/{mediaId} {
      // 🔒 SADECE KENDİ ADINA MEDYA OLUŞTURABİLİR
      allow create: if isSignedIn() && isOwner(request.resource.data.creatorId);
      allow read: if resource.data.visibility == 'public' || 
                   isOwner(resource.data.creatorId) || 
                   isAdmin();
      allow update, delete: if isOwner(resource.data.creatorId) || isAdmin();
    }

    // 📜 FINANCIAL LEDGER
    match /ledger/{entryId} {
      allow read: if isSignedIn() && (
                   resource.data.userId == request.auth.uid ||
                   resource.data.fromUserId == request.auth.uid ||
                   resource.data.toUserId == request.auth.uid ||
                   resource.data.creatorId == request.auth.uid ||
                   resource.data.userId == request.auth.token.walletAddress ||
                   resource.data.fromUserId == request.auth.token.walletAddress ||
                   resource.data.toUserId == request.auth.token.walletAddress ||
                   resource.data.creatorId == request.auth.token.walletAddress ||
                   isAdmin()
                 );
      allow write: if false; // ADMIN SDK ONLY
    }

    // 💳 SUBSCRIPTIONS
    match /subscriptions/{subId} {
      allow read: if isSignedIn() && (
                   resource.data.userId == request.auth.uid ||
                   resource.data.creatorId == request.auth.uid ||
                   resource.data.userId == request.auth.token.walletAddress ||
                   resource.data.creatorId == request.auth.token.walletAddress ||
                   isAdmin()
                 );
      allow write: if false; // ADMIN SDK ONLY
    }

    // 💰 CLAIM REQUESTS
    match /claim_requests/{claimId} {
      allow read: if isSignedIn() && (
                   resource.data.creatorId == request.auth.uid ||
                   resource.data.creatorId == request.auth.token.walletAddress ||
                   isAdmin()
                 );
      allow write: if isSignedIn() && (
                    isOwner(request.resource.data.creatorId) ||
                    isAdmin()
                  );
    }

    // ⏳ VESTING SCHEDULES
    match /vesting_schedules/{scheduleId} {
      allow read: if isSignedIn() && (
                   resource.data.userId == request.auth.uid ||
                   resource.data.userId == request.auth.token.walletAddress ||
                   isAdmin()
                 );
      allow write: if isAdmin();
    }

    // 🤖 AI GENERATION LOGS
    match /ai_generation_logs/{logId} {
      // 🔒 SADECE KENDİ ADINA LOG OLUŞTURABİLİR
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow read: if isOwner(resource.data.userId) || 
                   isOwner(resource.data.creatorId) || 
                   isAdmin();
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // 📰 POSTS (Public Content)
    match /posts/{postId} {
      allow read: if true;
      // create: Gelecek olan veriye (request.resource.data) bak
      allow create: if isSignedIn() && (isOwner(request.resource.data.creatorId) || isAdmin());
      // update/delete: Mevcut veriye (resource.data) bak
      allow update, delete: if isOwner(resource.data.creatorId) || isAdmin();
    }

    // ⚙️ SYSTEM CONFIG
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 💬 CHATS & MESSAGES
    match /chats/{chatId} {
      // 🔒 CREATE VE UPDATE/DELETE AYRILDI (Çökme Önlendi)
      allow read, update, delete: if isOwner(resource.data.subscriberId) || 
                                     isOwner(resource.data.creatorId) || 
                                     isAdmin();
                                     
      allow create: if isSignedIn() && (
                      isOwner(request.resource.data.subscriberId) || 
                      isOwner(request.resource.data.creatorId) || 
                      isAdmin()
                    );
      
      match /messages/{messageId} {
        // Parent dokümana (chatId) bakarak işlem izni
        allow read, update, delete: if isSignedIn() && (
          isOwner(get(/databases/$(database)/documents/chats/$(chatId)).data.subscriberId) ||
          isOwner(get(/databases/$(database)/documents/chats/$(chatId)).data.creatorId) ||
          isAdmin()
        );
        allow create: if isSignedIn() && (
          isOwner(get(/databases/$(database)/documents/chats/$(chatId)).data.subscriberId) ||
          isOwner(get(/databases/$(database)/documents/chats/$(chatId)).data.creatorId) ||
          isAdmin()
        );
      }
    }

    // 📊 PRESENTATIONS
    match /presentations/{presentationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 🏗️ DEFAULT FALLBACK
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
