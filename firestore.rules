rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ BASIC HELPERS
    // Note: Firestore rules do NOT support 'if' or 'return' keywords inside functions.
    // They must be single-expression boolean evaluations.
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && userId != null && (
        request.auth.uid == userId || 
        (exists(/databases/$(database)/documents/users/$(userId)) && 
         get(/databases/$(database)/documents/users/$(userId)).data.authUid == request.auth.uid)
      );
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // 👤 USER PROFILES
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // 📸 CREATOR MEDIA (Workshop / Drafts)
    match /creator_media/{mediaId} {
      allow create: if isSignedIn();
      allow read: if isOwner(resource.data.creatorId) || resource.data.visibility == 'public' || isAdmin();
      allow write: if isOwner(resource.data.creatorId) || isAdmin();
    }

    // 📜 FINANCIAL LEDGER
    match /ledger/{entryId} {
      allow read: if isOwner(resource.data.userId) || isOwner(resource.data.fromUserId) || isOwner(resource.data.toUserId) || isAdmin();
      allow write: if false; // ADMIN SDK ONLY
    }

    // 💳 SUBSCRIPTIONS
    match /subscriptions/{subId} {
      allow read: if isOwner(resource.data.userId) || isOwner(resource.data.creatorId) || isAdmin();
      allow write: if false; // ADMIN SDK ONLY
    }

    // 🤖 AI GENERATION LOGS
    match /ai_generation_logs/{logId} {
      allow read: if isOwner(resource.data.userId) || isOwner(resource.data.creatorId) || isAdmin();
      allow write: if isSignedIn(); 
    }

    // 📰 POSTS (Public Content)
    match /posts/{postId} {
      allow read: if true;
      allow write: if isOwner(resource.data.creatorId) || isAdmin();
    }

    // ⚙️ SYSTEM CONFIG
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 💬 CHATS & MESSAGES
    match /chats/{chatId} {
      allow read, write: if isOwner(resource.data.subscriberId) || isOwner(resource.data.creatorId) || isAdmin();
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // 🏗️ DEFAULT FALLBACK
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
