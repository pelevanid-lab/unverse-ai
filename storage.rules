rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /creator-media/{allPaths=**} {
      allow read: if true; // Publicly readable for Uniq Muse display
      allow write: if request.auth != null; // Authenticated users can upload
    }
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
